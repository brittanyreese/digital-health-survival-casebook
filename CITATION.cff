    family-names: Markides
    orcid: "https://orcid.org/0000-0001-6242-0842"
version: 1.0.2
license: MIT
repository-code: "https://github.com/brittanyreese/digital-health-survival-casebook"
url: "https://github.com/brittanyreese/digital-health-survival-casebook"
keywords:
